# Database
# For PostgreSQL: postgresql+asyncpg://user:password@localhost/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/odtrack_academia_fastapi

# Security - IMPORTANT: Generate a secure key for production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Debug Mode - Set to False in production
DEBUG=True

# CORS Origins - Add your frontend URLs
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:8000,http://127.0.0.1:8000,http://10.0.2.2:8000
